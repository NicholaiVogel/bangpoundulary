---
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';
interface Props { title?: string; description?: string; }
const path = Astro.url.pathname;
---
<html lang="en">
  <head>
    <BaseHead title={Astro.props.title} description={Astro.props.description} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Bangpoundulary home">
        <img class="brand-logo" src="/assets/bangpoundulary-logo-transparent.png" alt="" />
        <span class="brand-text">bangpoundulary.com</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a class={path === '/' ? 'active' : ''} href="/">Home</a>
        <a class={path.startsWith('/entries') ? 'active' : ''} href="/entries/">Browse Wombos</a>
        <a class={path.startsWith('/categories') ? 'active' : ''} href="/categories/">Categories</a>
        <a href="https://github.com/NicholaiVogel/bangpoundulary/issues/new">Submit a Wombo</a>
        <a class={path.startsWith('/about') ? 'active' : ''} href="/about/">About</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer class="site-footer">
      <div>
        <a class="footer-brand" href="/"><img class="brand-logo" src="/assets/bangpoundulary-logo-transparent.png" alt="" /><span>bangpoundulary.com</span></a>
        <p>The official dictionary of wombos<br />(word + combos).</p>
        <p>© 2026 Bangpoundulary.com</p>
      </div>
      <div class="footer-grid">
        <section>
          <h2>Explore</h2>
          <a href="/entries/">Browse Wombos</a>
          <a href="/categories/">Categories</a>
          <a href="/corpus/">Corpus</a>
        </section>
        <section>
          <h2>Contribute</h2>
          <a href="https://github.com/NicholaiVogel/bangpoundulary/issues/new">Submit a Wombo</a>
          <a href="/law/">Editorial Guidelines</a>
          <a href="https://github.com/NicholaiVogel/bangpoundulary">GitHub</a>
        </section>
        <section>
          <h2>About</h2>
          <a href="/about/">About Bangpoundulary</a>
          <a href="/law/">Our Principles</a>
          <a href="/search.json">Search JSON</a>
        </section>
        <section>
          <h2>Follow</h2>
          <div class="social-row" aria-label="Social links">
            <a href="https://github.com/NicholaiVogel/bangpoundulary" aria-label="GitHub">G</a>
            <a href="/corpus/" aria-label="Corpus">C</a>
            <a href="/law/" aria-label="Law">§</a>
          </div>
          <p>Made with words. For everyone.</p>
        </section>
      </div>
    </footer>
  </body>
</html>
