---
import type { BangEntry } from '../lib/entries';
const entries = Astro.props.entries as BangEntry[];
const compact = Boolean(Astro.props.compact);
const cleanText = (value = '') => String(value).replace(/[\u2014\u2013]/g, '-').replace(/\s+/g, ' ').replace(/^n\.\s*/i, '').trim();
const displayEntries = entries.map((entry) => ({
  slug: entry.slug,
  word: entry.word,
  author: entry.author,
  roots: entry.roots,
  status: entry.status,
  source: entry.source,
  definition: cleanText(entry.definition),
  sacrifice: cleanText(entry.sacrifice),
}));
const excerpt = (value = '', max = 190) => {
  const text = cleanText(value);
  return text.length > max ? `${text.slice(0, max).trim()}...` : text;
};
---
<section class:list={["search-panel", compact && "search-panel-compact"]} data-search-root>
  {!compact && <p class="section-kicker">Search the official record</p>}
  <div class="search-row">
    <span class="search-icon ph ph-magnifying-glass" aria-hidden="true"></span>
    <input id="bang-search" class="search-input" type="search" autocomplete="off" placeholder="Search wombos, roots, categories..." aria-label="Search wombos" />
    <button class="search-button" type="button">Search</button>
  </div>
  <div class="filters" aria-label="Status filters">
    <button data-status="all" class="active">All</button>
    <button data-status="valid">Valid</button>
    <button data-status="codified">Codified</button>
    <button data-status="deprecated">Deprecated</button>
    <button data-status="variant">Variants</button>
  </div>
  <div class="result-count"><span data-count>{entries.length}</span> records admitted</div>
  <div class="results" data-results>
    {displayEntries.slice(0, compact ? 8 : 24).map((entry) => (
      <a class="wombo-card" href={`/entries/${entry.slug}/`} data-status={entry.status}>
        <div class="card-topline"><span class={`pill pill-${entry.status}`}>{entry.status}</span></div>
        <h3>{entry.word}</h3>
        <p class="pronunciation">/{entry.slug.replaceAll('-', '·')}/ <span>{entry.roots.join(' + ')}</span></p>
        <p>{excerpt(entry.definition)}</p>
      </a>
    ))}
  </div>
</section>
<script define:vars={{ entries: displayEntries, compact }}>
  const root = document.querySelector('[data-search-root]');
  const input = root?.querySelector('#bang-search');
  const results = root?.querySelector('[data-results]');
  const count = root?.querySelector('[data-count]');
  const buttons = Array.from(root?.querySelectorAll('[data-status]') ?? []);
  const searchButton = root?.querySelector('.search-button');
  let activeStatus = 'all';

  const normalize = (value) => String(value ?? '').toLowerCase();
  const cleanText = (value) => String(value ?? '').replace(/[\u2014\u2013]/g, '-').replace(/\s+/g, ' ').replace(/^n\.\s*/i, '').trim();
  const escapeHtml = (value) => cleanText(value).replace(/[&<>'"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[char]));
  const excerpt = (value, max = 190) => {
    const text = cleanText(value);
    return text.length > max ? `${text.slice(0, max).trim()}...` : text;
  };
  const score = (entry, query) => {
    if (!query) return 1;
    const haystack = normalize([entry.word, entry.status, entry.author, entry.source, entry.definition, entry.roots?.join(' '), entry.sacrifice].join(' '));
    if (normalize(entry.word).startsWith(query)) return 100;
    if (normalize(entry.word).includes(query)) return 75;
    return haystack.includes(query) ? 25 : 0;
  };
  const card = (entry) => `
    <a class="wombo-card" href="/entries/${entry.slug}/" data-status="${escapeHtml(entry.status)}">
      <div class="card-topline"><span class="pill pill-${escapeHtml(entry.status)}">${escapeHtml(entry.status)}</span></div>
      <h3>${escapeHtml(entry.word)}</h3>
      <p class="pronunciation">/${escapeHtml(entry.slug.replaceAll('-', '·'))}/ <span>${escapeHtml((entry.roots || []).join(' + '))}</span></p>
      <p>${escapeHtml(excerpt(entry.definition))}</p>
    </a>`;
  const render = () => {
    const q = normalize(input?.value).trim();
    const filtered = entries
      .map((entry) => ({ entry, score: score(entry, q) }))
      .filter(({ entry, score }) => score > 0 && (activeStatus === 'all' || entry.status === activeStatus))
      .sort((a, b) => b.score - a.score || a.entry.word.localeCompare(b.entry.word))
      .slice(0, compact ? 12 : 72);
    if (count) count.textContent = String(filtered.length);
    if (!results) return;
    results.innerHTML = filtered.map(({ entry }) => card(entry)).join('') || '<p class="empty-record">No admissible record found. The court invites new evidence.</p>';
  };
  const submitSearch = () => {
    const q = normalize(input?.value).trim();
    if (compact) {
      window.location.href = q ? `/entries/?q=${encodeURIComponent(q)}` : '/entries/';
      return;
    }
    render();
  };
  const params = new URLSearchParams(window.location.search);
  const initialQuery = params.get('q');
  if (initialQuery && input) {
    input.value = initialQuery;
    render();
  }
  input?.addEventListener('input', render);
  input?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter') submitSearch();
  });
  searchButton?.addEventListener('click', submitSearch);
  buttons.forEach((button) => button.addEventListener('click', () => {
    activeStatus = button.dataset.status;
    buttons.forEach((b) => b.classList.toggle('active', b === button));
    render();
  }));
</script>
