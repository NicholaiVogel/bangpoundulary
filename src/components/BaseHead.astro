---
interface Props { title?: string; description?: string; }
const title = Astro.props.title ? `${Astro.props.title} · Bangpoundulary` : 'Bangpoundulary';
const description = Astro.props.description ?? 'The official dictionary of valid wombos, linguistic sacrifice, and court-admissible nonsense.';
---
<title>{title}</title>
<meta charset="utf-8" />
<meta name="description" content={description} />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url.href} />
<meta name="twitter:card" content="summary_large_image" />
<link rel="icon" href="/assets/bangpoundulary-logo-transparent.png" />
