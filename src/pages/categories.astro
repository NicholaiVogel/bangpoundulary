---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntries } from '../lib/entries';
const entries = getEntries();
const categoryDefs = [
  ['Culture', 'Institutions, politics, bro jurisprudence', /kirk|obama|trump|culture|bro/i, 'ph-users'],
  ['Internet', 'AI flow, scrolling, rizz, meme weather', /scroll|ai|meme|internet|discord|rizz|serotonin/i, 'ph-target'],
  ['Work', 'Operations, logistics, review, method', /pr|review|logistic|operation|workflow|method|computation/i, 'ph-selection'],
  ['Food', 'Quiche, brunch, snacks, edible comprehension', /quiche|food|brunch|snack|delicious|capiche/i, 'ph-bowl-steam'],
  ['Social', 'Mogging, influence, dominance, vibes', /mog|bro|social|influence|rizz|beta|alpha/i, 'ph-phone'],
];
const categories = categoryDefs.map(([name, desc, pattern, icon]) => {
  const matches = entries.filter((entry) => (pattern as RegExp).test(`${entry.word} ${entry.definition} ${entry.roots.join(' ')}`));
  return { name, desc, icon, count: matches.length, matches: matches.slice(0, 4) };
});
---
<BaseLayout title="Categories" description="Browse Bangpoundulary entries by institutional category.">
  <section class="page-intro categories-intro">
    <p class="section-kicker">Index divisions</p>
    <h1>Categories</h1>
    <p>Loose editorial shelves for a corpus that should not technically exist.</p>
  </section>

  <section class="category-directory category-directory-refined">
    {categories.map((category) => (
      <article class="category-panel category-panel-refined">
        <header>
          <span class="category-icon" aria-hidden="true"><i class={`ph ${category.icon}`}></i></span>
          <div>
            <h2>{category.name}</h2>
            <p>{category.desc}</p>
          </div>
          <strong>{category.count} wombos</strong>
        </header>
        <div class="category-sample-list">
          {category.matches.map((entry) => (
            <a href={`/entries/${entry.slug}/`}>
              <span>{entry.word}</span>
              <small>{entry.status}</small>
            </a>
          ))}
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
